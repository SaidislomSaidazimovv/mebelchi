{
  "name": "mebelchi-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Mebelchi headless engine core — UI-free, single entry point (solvePreview/solveFull).",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "vitest run --config vitest.bench.config.ts",
    "test:ui": "node tools/ui-size-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "puppeteer-core": "^23.11.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
