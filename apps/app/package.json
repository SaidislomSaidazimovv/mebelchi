{
  "name": "@mebelchi/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mebelchi customer app — React + Vite, wrapped with Capacitor (iOS/Android). The 6-phase journey + live 3D constructor.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:assets": "capacitor-assets generate --assetPath assets --iconBackgroundColor '#00a961' --iconBackgroundColorDark '#00a961' --splashBackgroundColor '#ffffff' --splashBackgroundColorDark '#0e0e0e'"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@supabase/supabase-js": "^2.109.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.11"
  }
}
