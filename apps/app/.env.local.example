# Copy this file to ".env.local" and paste your real keys (that file is gitignored).

# kie.ai API key — AI render (Preview step). HELD FOR v2: leave this UNSET in v1 so the
# key is never shipped in the client bundle. Re-enable by flipping AI_RENDER in
# src/config.ts (ideally proxy the key via a Supabase Edge Function then).
# VITE_KIE_API_KEY=your_kie_ai_key_here

# Supabase — auth + cloud sync of profiles/projects.
# Dashboard → Project Settings → API: "Project URL" and the "anon / public" key.
# (The anon key is safe in the client; Row-Level Security in supabase/schema.sql
# is what protects the data.)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
